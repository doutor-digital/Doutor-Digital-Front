# Modelo do ambiente de deploy do front-end. O arquivo real vive só na VPS em
# /opt/doutordigital/web/.env (chmod 600) e nunca é commitado.

# Dono do repositório no GHCR, minúsculas.
GHCR_OWNER=doutor-digital

# Tag da imagem (o CI sobrescreve com o SHA do commit).
IMAGE_TAG=latest

# Domínio servido pelo Traefik na VPS. Use o subdomínio novo enquanto valida;
# só aponte dashboard.doutordigitalconsultoria.com para cá na virada.
WEB_DOMAIN=dash-kommo.doutordigitalconsultoria.com
